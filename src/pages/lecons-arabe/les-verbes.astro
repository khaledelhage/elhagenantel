</style>

<script>
  // Tab switching for verb tables
  function setupTabs(tabContainerId: string, contentPrefix: string) {
    const tabs = document.querySelectorAll(`#${tabContainerId} .verb-tab`);
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const verb = (tab as HTMLElement).dataset.verb;
        document.querySelectorAll(`[id^="${contentPrefix}-"]`).forEach(c => c.classList.remove('active'));
        document.getElementById(`${contentPrefix}-${verb}`)!.classList.add('active');
      });
    });
  }

  setupTabs('madi-tabs', 'madi');
  setupTabs('mudari-tabs', 'mudari');

  // Smooth scroll for nav
  document.querySelectorAll('nav a').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      target!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.querySelectorAll('nav a').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
    });
  });

  // Active nav on scroll
  window.addEventListener('scroll', () => {
    const sections = document.querySelectorAll('section');
    let current = '';
    sections.forEach(section => {
      const top = section.offsetTop - 100;
      if (window.scrollY >= top) current = section.id;
    });
    document.querySelectorAll('nav a').forEach(link => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) link.classList.add('active');
    });
  });

  // Quiz System
  const quizQuestions = [
    {
      context: "Conjugue au ماضي",
      verb: "كَتَبَ",
      info: "Pronom : أَنَا (je)",
      correct: "كَتَبْتُ",
      options: ["كَتَبْتُ", "كَتَبْتَ", "أَكْتُبُ", "كَتَبَتْ"],
      explanation: "أَنَا au ماضي prend le suffixe ـتُ"
    },
    {
      context: "Conjugue au المضارع",
      verb: "كَتَبَ",
      info: "Pronom : هُوَ (il)",
      correct: "يَكْتُبُ",
      options: ["يَكْتُبُ", "تَكْتُبُ", "أَكْتُبُ", "كَتَبَ"],
      explanation: "هُوَ au المضارع prend le préfixe يـ"
    },
    {
      context: "Conjugue au ماضي",
      verb: "ذَهَبَ",
      info: "Pronom : هِيَ (elle)",
      correct: "ذَهَبَتْ",
      options: ["ذَهَبَتْ", "ذَهَبَ", "تَذْهَبُ", "ذَهَبْتُ"],
      explanation: "هِيَ au ماضي prend le suffixe ـتْ"
    },
    {
      context: "Conjugue au المضارع",
      verb: "جَلَسَ",
      info: "Pronom : نَحْنُ (nous)",
      correct: "نَجْلِسُ",
      options: ["نَجْلِسُ", "يَجْلِسُ", "جَلَسْنَا", "تَجْلِسُ"],
      explanation: "نَحْنُ au المضارع prend le préfixe نـ"
    },
    {
      context: "Conjugue au ماضي",
      verb: "فَتَحَ",
      info: "Pronom : هُمْ (ils)",
      correct: "فَتَحُوا",
      options: ["فَتَحُوا", "يَفْتَحُونَ", "فَتَحْنَا", "فَتَحَ"],
      explanation: "هُمْ au ماضي prend le suffixe ـوا"
    },
    {
      context: "Conjugue au المضارع",
      verb: "فَتَحَ",
      info: "Pronom : أَنْتِ (tu, fém.)",
      correct: "تَفْتَحِينَ",
      options: ["تَفْتَحِينَ", "تَفْتَحُ", "فَتَحْتِ", "يَفْتَحُ"],
      explanation: "أَنْتِ au المضارع prend le préfixe تـ et le suffixe ـينَ"
    },
    {
      context: "Conjugue au ماضي",
      verb: "كَتَبَ",
      info: "Pronom : نَحْنُ (nous)",
      correct: "كَتَبْنَا",
      options: ["كَتَبْنَا", "نَكْتُبُ", "كَتَبُوا", "كَتَبْتُمْ"],
      explanation: "نَحْنُ au ماضي prend le suffixe ـنَا"
    },
    {
      context: "Conjugue au المضارع",
      verb: "ذَهَبَ",
      info: "Pronom : أَنَا (je)",
      correct: "أَذْهَبُ",
      options: ["أَذْهَبُ", "يَذْهَبُ", "ذَهَبْتُ", "نَذْهَبُ"],
      explanation: "أَنَا au المضارع prend le préfixe أ"
    },
    {
      context: "Quel est le temps de ce verbe ?",
      verb: "يَجْلِسُونَ",
      info: "ماضي ou مضارع ?",
      correct: "المضارع",
      options: ["المضارع", "الماضي"],
      explanation: "Le préfixe يـ et le suffixe ـونَ indiquent le المضارع (ils)"
    },
    {
      context: "Quel est le temps de ce verbe ?",
      verb: "فَتَحْتُمْ",
      info: "ماضي ou مضارع ?",
      correct: "الماضي",
      options: ["الماضي", "المضارع"],
      explanation: "Le suffixe ـتُمْ sans préfixe indique le ماضي (vous, masc. pl.)"
    },
    {
      context: "Conjugue au المضارع",
      verb: "جَلَسَ",
      info: "Pronom : هُمْ (ils)",
      correct: "يَجْلِسُونَ",
      options: ["يَجْلِسُونَ", "جَلَسُوا", "تَجْلِسُونَ", "يَجْلِسُ"],
      explanation: "هُمْ au المضارع prend le préfixe يـ et le suffixe ـونَ"
    },
    {
      context: "Conjugue au ماضي",
      verb: "ذَهَبَ",
      info: "Pronom : أَنْتَ (tu, masc.)",
      correct: "ذَهَبْتَ",
      options: ["ذَهَبْتَ", "ذَهَبْتِ", "تَذْهَبُ", "ذَهَبَ"],
      explanation: "أَنْتَ au ماضي prend le suffixe ـتَ (avec fatḥa)"
    },
  ];

  let currentQuestion = 0;
  let score = 0;
  let totalAnswered = 0;
  let shuffledQuestions: typeof quizQuestions = [];

  function shuffleArray<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function loadQuestion() {
    if (currentQuestion >= shuffledQuestions.length) {
      shuffledQuestions = shuffleArray(quizQuestions);
      currentQuestion = 0;
    }

    const q = shuffledQuestions[currentQuestion];
    document.getElementById('quiz-context')!.textContent = q.context;
    document.getElementById('quiz-verb')!.textContent = q.verb;
    document.getElementById('quiz-info')!.textContent = q.info;

    const optionsDiv = document.getElementById('quiz-options')!;
    optionsDiv.innerHTML = '';

    const shuffledOptions = shuffleArray(q.options);
    shuffledOptions.forEach(opt => {
      const btn = document.createElement('div');
      btn.className = 'quiz-option';
      btn.textContent = opt;
      btn.addEventListener('click', () => checkAnswer(btn, opt, q));
      optionsDiv.appendChild(btn);
    });

    document.getElementById('quiz-feedback')!.className = 'quiz-feedback';
    document.getElementById('quiz-feedback')!.style.display = 'none';
    document.getElementById('next-btn')!.style.display = 'none';
  }

  function checkAnswer(btn: HTMLElement, selected: string, question: typeof quizQuestions[0]) {
    const options = document.querySelectorAll('.quiz-option');
    options.forEach(o => o.classList.add('disabled'));

    totalAnswered++;
    const feedback = document.getElementById('quiz-feedback')!;

    if (selected === question.correct) {
      score++;
      btn.classList.add('correct');
      feedback.className = 'quiz-feedback show correct';
      feedback.innerHTML = `Correct! ${question.explanation}`;
    } else {
      btn.classList.add('wrong');
      options.forEach(o => {
        if (o.textContent === question.correct) o.classList.add('correct');
      });
      feedback.className = 'quiz-feedback show wrong';
      feedback.innerHTML = `La bonne réponse était <strong>${question.correct}</strong>. ${question.explanation}`;
    }

    document.getElementById('score')!.textContent = String(score);
    document.getElementById('total')!.textContent = String(totalAnswered);
    document.getElementById('next-btn')!.style.display = 'inline-block';
  }

  function nextQuestion() {
    currentQuestion++;
    loadQuestion();
  }

  // Wire up next button
  document.getElementById('next-btn')!.addEventListener('click', nextQuestion);

  // Initialize
  shuffledQuestions = shuffleArray(quizQuestions);
  loadQuestion();
</script>
