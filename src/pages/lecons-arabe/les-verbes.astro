        <div class="label">الماضي : le passé</div>
        <h4>كَتَبَ</h4>
        <div class="meaning">il a écrit</div>
        <div class="example" style="margin-top:1rem">كَتَبَ الوَلَدُ رِسَالَةً</div>
        <div class="meaning">Le garçon a écrit une lettre</div>
      </div>
      <div class="comparison-col present">
        <div class="label">المضارع : le présent</div>
        <h4>يَكْتُبُ</h4>
        <div class="meaning">il écrit</div>
        <div class="example" style="margin-top:1rem">يَكْتُبُ الوَلَدُ رِسَالَةً</div>
        <div class="meaning">Le garçon écrit une lettre</div>
      </div>
    </div>

    <div class="concept-box teal">
      <h4>Résumé des mécanismes</h4>
      <table class="summary-table">
        <thead>
          <tr><th>Aspect</th><th>الماضي</th><th>المضارع</th></tr>
        </thead>
        <tbody>
          <tr><td>Modification</td><td>Suffixes (fin)</td><td>Préfixes (début) + suffixes</td></tr>
          <tr><td>Sens</td><td>Action accomplie</td><td>Action en cours / future</td></tr>
          <tr><td>Difficulté</td><td>Plus simple</td><td>Voyelle variable à mémoriser</td></tr>
          <tr><td>Équivalent FR</td><td>Passé composé / simple</td><td>Présent / futur</td></tr>
        </tbody>
      </table>
    </div>
  </section>

