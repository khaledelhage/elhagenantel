    margin-top: 0.3rem;
    width: fit-content;
  }

  /* Conjugation tables */
  .conj-table-wrapper {
    overflow-x: auto;
    margin: 1rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  thead {
    background: var(--bg-dark);
    color: #fff;
  }

  th {
    padding: 0.8rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.85rem;
  }

  th.ar {
    font-family: 'Amiri', serif;
    font-size: 1.1rem;
    direction: rtl;
    text-align: right;
  }

  td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  tbody tr:hover { background: var(--accent-light); }

  .pronoun-fr {
    font-weight: 600;
    color: var(--text);
    font-size: 0.9rem;
  }

  .pronoun-ar {
    font-family: 'Amiri', serif;
    font-size: 1.2em;
    direction: rtl;
    color: var(--text-arabic);
    text-align: right;
  }

  .verb-ar {
    font-family: 'Amiri', serif;
    font-size: 1.4em;
    direction: rtl;
    font-weight: 700;
    color: var(--accent-dark);
    text-align: right;
  }

  /* Verb tabs */
  .verb-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .verb-tab {
    padding: 0.6rem 1.2rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .verb-tab:hover { border-color: var(--accent); }

  .verb-tab.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .tab-arabic {
    font-family: 'Amiri', serif;
    font-size: 1.1em;
    direction: rtl;
  }

  .verb-content { display: none; }
  .verb-content.active { display: block; }

  /* Pronoun order toggle */
  .pronoun-order-toggle {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.8rem 1.2rem;
    margin: 1rem 0;
    box-shadow: var(--shadow);
  }

  .toggle-label {
    font-size: 0.85rem;
    color: var(--text-light);
    white-space: nowrap;
  }

  .toggle-buttons { display: flex; gap: 0.5rem; }

  .toggle-btn {
    padding: 0.4rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.82rem;
    font-family: 'Lora', serif;
    transition: all 0.2s ease;
    color: var(--text);
  }

  .toggle-btn:hover { border-color: var(--accent); }

  .toggle-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .group-header td {
    background: var(--accent-light);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
  }

  /* Quiz Section */
  .quiz-area {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    margin: 1.5rem 0;
    box-shadow: var(--shadow);
  }

  .quiz-prompt {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .quiz-prompt .context {
    font-size: 0.95rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .quiz-prompt .question-verb {
    font-family: 'Amiri', serif;
    font-size: 2.2rem;
    color: var(--text-arabic);
    direction: rtl;
  }

  .quiz-prompt .question-info {
    font-size: 1rem;
    color: var(--accent-dark);
    margin-top: 0.5rem;
    font-weight: 600;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .quiz-option {
    padding: 1rem;
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
    font-family: 'Amiri', serif;
    font-size: 1.4rem;
    direction: rtl;
  }

  .quiz-option.fr-option {
    font-family: 'Lora', Georgia, serif;
    font-size: 1rem;
    direction: ltr;
  }

  .quiz-option:hover:not(.disabled) {
    border-color: var(--accent);
    background: var(--accent-light);
    transform: translateY(-1px);
  }

  .quiz-option.correct { border-color: var(--correct); background: var(--correct); color: #fff; }
  .quiz-option.wrong { border-color: var(--wrong); background: var(--wrong); color: #fff; }
  .quiz-option.disabled { cursor: default; opacity: 0.7; }

  .quiz-feedback {
    text-align: center;
    padding: 1rem;
    border-radius: 8px;
    margin-top: 1rem;
    display: none;
    font-size: 0.95rem;
  }

  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct { background: var(--correct-bg); color: var(--correct); }
  .quiz-feedback.wrong { background: var(--wrong-bg); color: var(--wrong); }

  .quiz-controls { text-align: center; margin-top: 1.2rem; }

  .btn {
    padding: 0.7rem 2rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Lora', serif;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn:hover { background: var(--accent-dark); transform: translateY(-1px); }

  .score-display {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-light);
    margin-bottom: 1rem;
  }

  .score-display strong { color: var(--teal); font-size: 1.1em; }
  .score-separator { margin: 0 0.8rem; color: var(--border); }

  /* Footer */
  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-light);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
  }

  /* Responsive */
  @media (max-width: 600px) {
    header h1 { font-size: 2rem; }
    nav a { padding: 0.8rem 1rem; font-size: 0.85rem; }
    main { padding: 1.5rem 1rem 3rem; }
    .absence-comparison { gap: 1rem; }
    .time-comparison { grid-template-columns: 1fr; }
    .time-arrow { text-align: center; transform: rotate(90deg); }
    .future-cards { grid-template-columns: 1fr; }
    .tanwin-grid { grid-template-columns: 1fr; }
    .quiz-options { grid-template-columns: 1fr; }
    .vocab-grid { grid-template-columns: repeat(2, 1fr); }
    .verb-tabs { flex-direction: column; }
    .pronoun-order-toggle { flex-direction: column; align-items: flex-start; }
    .case-label { min-width: auto; }
  }
</style>

<script>
  // Pronoun order toggle
  const GROUPED_ORDER = ['Je', 'Tu (masc.)', 'Tu (fém.)', 'Il', 'Elle', 'Vous (duel)', 'Ils (duel)', 'Elles (duel)', 'Nous', 'Vous (masc. pl.)', 'Vous (fém. pl.)', 'Ils (pl.)', 'Elles (pl.)'];
  const TRADITIONAL_ORDER = ['Je', 'Tu (masc.)', 'Tu (fém.)', 'Il', 'Elle', 'Nous', 'Vous (duel)', 'Vous (masc. pl.)', 'Vous (fém. pl.)', 'Ils (duel)', 'Elles (duel)', 'Ils (pl.)', 'Elles (pl.)'];
  const GROUP_STARTS: Record<string, string> = { 'Je': 'Singulier', 'Vous (duel)': 'Duel', 'Nous': 'Pluriel' };

  function reorderAllTables(order: string[], showGroups: boolean) {
    document.querySelectorAll('tbody').forEach(tbody => {
      const rows = Array.from(tbody.querySelectorAll('tr:not(.group-header)'));
      if (!rows.length) return;
      const pronouns = rows.map(r => r.querySelector('.pronoun-fr')?.textContent?.trim() || '');
      if (!pronouns.every(p => order.includes(p))) return;

      tbody.querySelectorAll('.group-header').forEach(h => h.remove());

      rows.sort((a, b) => {
        const aName = a.querySelector('.pronoun-fr')?.textContent?.trim() || '';
        const bName = b.querySelector('.pronoun-fr')?.textContent?.trim() || '';
        return order.indexOf(aName) - order.indexOf(bName);
      });

      rows.forEach(row => {
        const name = row.querySelector('.pronoun-fr')?.textContent?.trim() || '';
        if (showGroups && GROUP_STARTS[name]) {
          const header = document.createElement('tr');
          header.className = 'group-header';
          const td = document.createElement('td');
          td.colSpan = row.children.length;
          td.textContent = GROUP_STARTS[name];
          header.appendChild(td);
          tbody.appendChild(header);
        }
        tbody.appendChild(row);
      });
    });
  }

  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const order = (btn as HTMLElement).dataset.order;
      if (order === 'grouped') {
        reorderAllTables(GROUPED_ORDER, true);
      } else {
        reorderAllTables(TRADITIONAL_ORDER, false);
      }
    });
  });

  reorderAllTables(GROUPED_ORDER, true);

  // Tab switching for verb tables
  function setupTabs(tabContainerId: string, contentPrefix: string) {
    const tabs = document.querySelectorAll(`#${tabContainerId} .verb-tab`);
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const verb = (tab as HTMLElement).dataset.verb;
        document.querySelectorAll(`[id^="${contentPrefix}-"]`).forEach(c => c.classList.remove('active'));
        document.getElementById(`${contentPrefix}-${verb}`)!.classList.add('active');
      });
    });
  }

  setupTabs('conj-tabs', 'conj');

  // Smooth scroll for nav
  document.querySelectorAll('nav a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      target!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.querySelectorAll('nav a').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
    });
  });

  // Active nav on scroll
  window.addEventListener('scroll', () => {
    const sections = document.querySelectorAll('section');
    let current = '';
    sections.forEach(section => {
      const top = section.offsetTop - 100;
      if (window.scrollY >= top) current = section.id;
    });
    document.querySelectorAll('nav a[href^="#"]').forEach(link => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) link.classList.add('active');
    });
  });

  // Quiz System
  interface QuizQuestion {
    context: string;
    verb: string;
    info: string;
    correct: string;
    options: string[];
    explanation: string;
    frOptions?: boolean;
  }

  const quizQuestions: QuizQuestion[] = [
    {
      context: "Comment dit-on « il était grand » ?",
      verb: "كَبِير + هُوَ",
      info: "Utilise كَانَ",
      correct: "كَانَ كَبِيرًا",
      options: ["كَانَ كَبِيرًا", "كَانَ كَبِيرٌ", "يَكُونُ كَبِيرًا", "كَبِيرٌ كَانَ"],
      explanation: "Après كَانَ, l'attribut passe au منصوب (tanwīn fatḥa) : كَبِيرٌ → كَبِيرًا."
    },
    {
      context: "Traduis : « La maison est grande »",
      verb: "البَيْت + كَبِير",
      info: "Phrase nominale (présent, sans verbe)",
      correct: "البَيْتُ كَبِيرٌ",
      options: ["البَيْتُ كَبِيرٌ", "كَانَ البَيْتُ كَبِيرًا", "البَيْتُ كَبِيرًا", "يَكُونُ البَيْتُ كَبِيرًا"],
      explanation: "Dans la phrase nominale (présent), pas de verbe « être » en arabe. On juxtapose sujet + attribut (les deux au مرفوع)."
    },
    {
      context: "Conjugue كَانَ à la 1re personne (أَنَا) :",
      verb: "كَانَ",
      info: "الماضي",
      correct: "كُنْتُ",
      options: ["كُنْتُ", "كَانَ", "أَكُونُ", "كُنَّا"],
      explanation: "Au ماضي, كَانَ avec أَنَا donne كُنْتُ. Le و de la racine ك و ن disparaît devant le suffixe."
    },
    {
      context: "Que signifie أَصْبَحَ ?",
      verb: "أَصْبَحَ",
      info: "",
      correct: "Il est devenu",
      options: ["Il est devenu", "Il était", "Il sera", "Il écrit"],
      frOptions: true,
      explanation: "أَصْبَحَ exprime un changement d'état : « devenir » ou « se retrouver dans un nouvel état »."
    },
    {
      context: "Complète : كَانَ ... يَدْرُسُ",
      verb: "Il étudiait (imparfait)",
      info: "هُوَ (il)",
      correct: "كَانَ يَدْرُسُ",
      options: ["كَانَ يَدْرُسُ", "كَانَ دَرَسَ", "سَيَدْرُسُ", "يَكُونُ يَدْرُسُ"],
      frOptions: true,
      explanation: "كَانَ + المضارع (inaccompli) = imparfait. كَانَ يَدْرُسُ = il étudiait / il était en train d'étudier."
    },
    {
      context: "Comment exprimer le futur en arabe ?",
      verb: "سَـ / سَوْفَ",
      info: "Quelle construction ?",
      correct: "سَـ + المضارع (inaccompli)",
      options: ["سَـ + المضارع (inaccompli)", "كَانَ + المضارع (inaccompli)", "سَـ + الماضي", "أَصْبَحَ + المضارع (inaccompli)"],
      frOptions: true,
      explanation: "Le futur se forme avec سَـ ou سَوْفَ + le verbe au المضارع (inaccompli) : سَأَذْهَبُ = j'irai."
    },
    {
      context: "Quel est le المضارع (inaccompli) de كَانَ (هُوَ) ?",
      verb: "كَانَ → ?",
      info: "المضارع المرفوع (inaccompli indicatif)",
      correct: "يَكُونُ",
      options: ["يَكُونُ", "كَانَ", "يَكُونَ", "كُنْتُ"],
      explanation: "Le المضارع (inaccompli) de كَانَ pour هُوَ est يَكُونُ (yakūnu). Le و de la racine apparaît comme voyelle longue."
    },
    {
      context: "Traduis : « Elle deviendra médecin »",
      verb: "أَصْبَحَ + طَبِيبَة",
      info: "Utilise le futur",
      correct: "سَتُصْبِحُ طَبِيبَةً",
      options: ["سَتُصْبِحُ طَبِيبَةً", "أَصْبَحَتْ طَبِيبَةً", "تُصْبِحُ طَبِيبَةٌ", "كَانَتْ طَبِيبَةً"],
      explanation: "Futur de أَصْبَحَ : سَـ + تُصْبِحُ (elle). L'attribut reste au منصوب : طَبِيبَةً."
    },
    {
      context: "Quelle est la forme correcte de l'attribut après كَانَ ?",
      verb: "كَانَ الجَوُّ ...",
      info: "جَمِيل (beau)",
      correct: "جَمِيلًا",
      options: ["جَمِيلًا", "جَمِيلٌ", "جَمِيلٍ", "جَمِيلَ"],
      explanation: "L'attribut de كَانَ (خبر كَانَ) est au منصوب : tanwīn fatḥa → جَمِيلًا."
    },
    {
      context: "Conjugue أَصْبَحَ au الماضي pour نَحْنُ :",
      verb: "أَصْبَحَ",
      info: "نَحْنُ (nous)",
      correct: "أَصْبَحْنَا",
      options: ["أَصْبَحْنَا", "أَصْبَحُوا", "نُصْبِحُ", "أَصْبَحْتُ"],
      explanation: "أَصْبَحَ avec نَحْنُ au ماضي : أَصْبَحْنَا (nous sommes devenus)."
    },
    {
      context: "Traduis : « Nous habitions à Beyrouth »",
      verb: "سَكَنَ / يَسْكُنُ (habiter)",
      info: "نَحْنُ (nous), imparfait",
      correct: "كُنَّا نَسْكُنُ فِي بَيْرُوتَ",
      options: ["كُنَّا نَسْكُنُ فِي بَيْرُوتَ", "سَنَسْكُنُ فِي بَيْرُوتَ", "نَسْكُنُ فِي بَيْرُوتَ", "سَكَنَّا فِي بَيْرُوتَ"],
      explanation: "Imparfait = كَانَ (ماضي) + المضارع (inaccompli). كُنَّا نَسْكُنُ = nous habitions."
    },
    {
      context: "Le المنصوب de يَكُونُ (هُوَ) est :",
      verb: "يَكُونُ → ?",
      info: "Subjonctif",
      correct: "يَكُونَ",
      options: ["يَكُونَ", "يَكُونُ", "كَانَ", "يَكُونُوا"],
      explanation: "Au منصوب (subjonctif), la ضمّة finale devient فتحة : يَكُونُ → يَكُونَ."
    },
    {
      context: "Complète : يَجِبُ أَنْ ... صَادِقًا",
      verb: "Tu dois être honnête",
      info: "كَانَ, أَنْتَ, subjonctif",
      correct: "تَكُونَ",
      options: ["تَكُونَ", "تَكُونُ", "كُنْتَ", "سَتَكُونُ"],
      explanation: "Après أَنْ, le verbe passe au منصوب : يَجِبُ أَنْ تَكُونَ = tu dois être."
    },
    {
      context: "Traduis : « Le temps sera beau »",
      verb: "الطَّقْس + جَمِيل",
      info: "Futur avec كَانَ",
      correct: "سَيَكُونُ الطَّقْسُ جَمِيلًا",
      options: ["سَيَكُونُ الطَّقْسُ جَمِيلًا", "كَانَ الطَّقْسُ جَمِيلًا", "الطَّقْسُ جَمِيلٌ", "سَيَكُونُ الطَّقْسُ جَمِيلٌ"],
      explanation: "Futur = سَـ + يَكُونُ. L'attribut reste au منصوب : جَمِيلًا."
    },
    {
      context: "Pourquoi dit-on كُنْتُ et non كَوَنْتُ ?",
      verb: "كَانَ → كُنْتُ",
      info: "",
      correct: "La lettre و (faible) disparaît devant un suffixe consonne",
      options: ["La lettre و (faible) disparaît devant un suffixe consonne", "C'est une exception sans explication", "Le ماضي utilise toujours كُ au lieu de كَوَ", "Le أ initial tombe au ماضي"],
      frOptions: true,
      explanation: "كَانَ est un verbe creux (أَجْوَف). La lettre و de la racine ك و ن disparaît quand un suffixe commençant par une consonne est ajouté."
    },
  ];

  let currentQuestion = 0;
  let score = 0;
  let totalAnswered = 0;
  let shuffledQuestions: QuizQuestion[] = [];
  let answered = false;

  function shuffleArray<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function loadQuestion() {
    answered = false;

    if (currentQuestion >= shuffledQuestions.length) {
      shuffledQuestions = shuffleArray(quizQuestions);
      currentQuestion = 0;
    }

    const q = shuffledQuestions[currentQuestion];
    document.getElementById('quiz-context')!.textContent = q.context;
    const verbEl = document.getElementById('quiz-verb')!;
    verbEl.textContent = q.verb;
    verbEl.style.direction = /[\u0600-\u06FF]/.test(q.verb) ? 'rtl' : 'ltr';
    document.getElementById('quiz-info')!.textContent = q.info;

    const optionsDiv = document.getElementById('quiz-options')!;
    optionsDiv.innerHTML = '';

    const shuffledOptions = shuffleArray(q.options);
    shuffledOptions.forEach(opt => {
      const btn = document.createElement('div');
      btn.className = 'quiz-option' + (q.frOptions ? ' fr-option' : '');
      btn.textContent = opt;
      btn.addEventListener('click', () => checkAnswer(btn, opt, q));
      optionsDiv.appendChild(btn);
    });

    document.getElementById('quiz-feedback')!.className = 'quiz-feedback';
    document.getElementById('quiz-feedback')!.style.display = 'none';
    document.getElementById('next-btn')!.style.display = 'none';
  }

  function checkAnswer(btn: HTMLElement, selected: string, question: QuizQuestion) {
    if (answered) return;
    answered = true;

    const options = document.querySelectorAll('.quiz-option');
    options.forEach(o => o.classList.add('disabled'));

    const feedback = document.getElementById('quiz-feedback')!;

    if (selected === question.correct) {
      score++;
      btn.classList.add('correct');
      feedback.className = 'quiz-feedback show correct';
      feedback.innerHTML = `Correct! ${question.explanation}`;
      document.getElementById('score')!.textContent = String(score);
    } else {
      btn.classList.add('wrong');
      options.forEach(o => {
        if (o.textContent === question.correct) o.classList.add('correct');
      });
      feedback.className = 'quiz-feedback show wrong';
      feedback.innerHTML = `La bonne réponse était <strong>${question.correct}</strong>. ${question.explanation}`;
    }

    document.getElementById('next-btn')!.style.display = 'inline-block';
  }

  function nextQuestion() {
    totalAnswered++;
    document.getElementById('progress')!.textContent = String(totalAnswered);
    currentQuestion++;
    loadQuestion();
  }

  // Wire up next button
  document.getElementById('next-btn')!.addEventListener('click', nextQuestion);

  // Initialize
  shuffledQuestions = shuffleArray(quizQuestions);
  document.getElementById('total')!.textContent = String(quizQuestions.length);
  loadQuestion();
</script>
