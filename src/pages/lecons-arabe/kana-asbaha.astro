  /* Sentence cards */
  .sentence-examples { margin: 1.5rem 0; }

  .sentence-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.2rem 1.5rem;
    margin-bottom: 0.8rem;
