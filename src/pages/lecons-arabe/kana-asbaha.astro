  }

  .absence-comparison {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .absence-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg-card);
    padding: 1.2rem 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .absence-lang {
    font-size: 0.8rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .absence-sentence { font-size: 1.1rem; }
  .absence-etre { color: var(--wrong); font-weight: 700; text-decoration: line-through; }

  .absence-translit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
