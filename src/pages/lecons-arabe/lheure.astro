    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: transform 0.2s ease;
  }

  .sentence-card:hover { transform: translateX(4px); }

  .sentence-card .ar-line { font-family: 'Amiri', serif; font-size: 1.5rem; direction: rtl; text-align: right; color: var(--text-arabic); }
  .sentence-card .fr-line { color: var(--text-light); font-size: 0.9rem; font-style: italic; }
  .sentence-card .note { font-size: 0.8rem; color: var(--accent-dark); background: var(--accent-light); display: inline-block; padding: 0.2rem 0.6rem; border-radius: 4px; margin-top: 0.3rem; width: fit-content; }

  /* Vocab grid */
  .vocab-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.8rem;
    margin-top: 0.5rem;
  }

  .vocab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem;
    background: var(--teal-light);
    border-radius: 8px;
  }

  .concept-box.highlight .vocab-item { background: var(--accent-light); }
  .vocab-item .arabic { font-size: 1.2em; }
  .vocab-fr { font-size: 0.85rem; color: var(--text-light); }

  /* Quiz */
  .quiz-area { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2rem; margin: 1.5rem 0; box-shadow: var(--shadow); }
  .quiz-prompt { text-align: center; margin-bottom: 1.5rem; }
  .quiz-prompt .context { font-size: 0.95rem; color: var(--text-light); margin-bottom: 0.5rem; }
  .quiz-prompt .question-verb { font-family: 'Amiri', serif; font-size: 2.2rem; color: var(--text-arabic); direction: rtl; }
  .quiz-prompt .question-info { font-size: 1rem; color: var(--accent-dark); margin-top: 0.5rem; font-weight: 600; }
  .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-bottom: 1rem; }

  .quiz-option {
    padding: 1rem;
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
    font-family: 'Amiri', serif;
    font-size: 1.4rem;
    direction: rtl;
  }

  .quiz-option:hover:not(.disabled) { border-color: var(--accent); background: var(--accent-light); transform: translateY(-1px); }
  .quiz-option.correct { border-color: var(--correct); background: var(--correct); color: #fff; }
  .quiz-option.wrong { border-color: var(--wrong); background: var(--wrong); color: #fff; }
  .quiz-option.disabled { cursor: default; opacity: 0.7; }
  .quiz-option.fr-option { font-family: 'Lora', Georgia, serif; font-size: 1rem; direction: ltr; }

  .quiz-feedback { text-align: center; padding: 1rem; border-radius: 8px; margin-top: 1rem; display: none; font-size: 0.95rem; }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct { background: var(--correct-bg); color: var(--correct); }
  .quiz-feedback.wrong { background: var(--wrong-bg); color: var(--wrong); }
  .quiz-controls { text-align: center; margin-top: 1.2rem; }

  .btn { padding: 0.7rem 2rem; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-family: 'Lora', serif; font-size: 1rem; cursor: pointer; transition: all 0.2s ease; }
  .btn:hover { background: var(--accent-dark); transform: translateY(-1px); }
  .score-display { text-align: center; font-size: 0.95rem; color: var(--text-light); margin-bottom: 1rem; }
  .score-display strong { color: var(--teal); font-size: 1.1em; }
  .score-separator { margin: 0 0.8rem; color: var(--border); }

  /* Footer */
  footer { text-align: center; padding: 2rem; color: var(--text-light); font-size: 0.85rem; border-top: 1px solid var(--border); }

  /* Responsive */
  @media (max-width: 600px) {
    header h1 { font-size: 2rem; }
    .time-cards { grid-template-columns: repeat(2, 1fr); }
    .clock-card { flex-direction: column; text-align: center; gap: 0.8rem; }
    .clock-text .ar-line { text-align: center; }
    .quiz-options { grid-template-columns: 1fr; }
    .vocab-grid { grid-template-columns: repeat(2, 1fr); }
    nav a { padding: 0.8rem 1rem; font-size: 0.85rem; }
    main { padding: 1.5rem 1rem 3rem; }
    .number-cards { gap: 0.6rem; }
    .number-card { min-width: 100px; padding: 0.8rem 0.8rem; }
    .structure-demo { flex-direction: column; }
    .digit-row { flex-direction: column; gap: 0.2rem; }
    .digit-label { min-width: auto; }
  }
</style>

<script>
  // Smooth scroll for nav
  document.querySelectorAll('nav a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      target!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.querySelectorAll('nav a').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
    });
  });

  // Active nav on scroll
  window.addEventListener('scroll', () => {
    const sections = document.querySelectorAll('section');
    let current = '';
    sections.forEach(section => {
      const top = section.offsetTop - 100;
      if (window.scrollY >= top) current = section.id;
    });
    document.querySelectorAll('nav a[href^="#"]').forEach(link => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) link.classList.add('active');
    });
  });

  // Quiz System
  const quizQuestions = [
    {
      context: "Comment dit-on « quelle heure est-il ? »",
      verb: "Quelle heure est-il ?",
      info: "",
      correct: "كَمِ السَّاعَة؟",
      options: ["كَمِ السَّاعَة؟", "أَيْنَ السَّاعَة؟", "مَا السَّاعَة؟", "هَلِ السَّاعَة؟"],
      explanation: "كَم = combien/quelle, كَمِ السَّاعَة؟ = quelle heure est-il ?"
    },
    {
      context: "Quelle heure indique-t-on ?",
      verb: "السَّاعَةُ الثَّالِثَة",
      info: "",
      correct: "3:00",
      options: ["3:00", "4:00", "2:00", "6:00"],
      explanation: "الثَّالِثَة = troisième, donc il est 3:00",
      frOptions: true
    },
    {
      context: "Comment dit-on « 5 heures et demie » ?",
      verb: "5:30",
      info: "",
      correct: "السَّاعَةُ الخَامِسَة وَالنِّصْف",
      options: ["السَّاعَةُ الخَامِسَة وَالنِّصْف", "السَّاعَةُ الخَامِسَة وَالرُّبْع", "السَّاعَةُ السَّادِسَة إِلَّا رُبْعًا", "السَّاعَةُ الخَامِسَة تَمَامًا"],
      explanation: "وَالنِّصْف = et demie, الخَامِسَة = cinquième"
    },
    {
      context: "Que signifie cette heure ?",
      verb: "السَّاعَةُ التَّاسِعَة إِلَّا رُبْعًا",
      info: "",
      correct: "8:45",
      options: ["8:45", "9:15", "9:45", "8:15"],
      explanation: "التَّاسِعَة إِلَّا رُبْعًا = neuf heures moins le quart = 8:45",
      frOptions: true
    },
    {
      context: "Comment dit-on « et quart » ?",
      verb: "وَ + ?",
      info: "Quelle fraction ?",
      correct: "وَالرُّبْع",
      options: ["وَالرُّبْع", "وَالنِّصْف", "وَالثُّلْث", "إِلَّا رُبْعًا"],
      explanation: "رُبْع = quart, وَالرُّبْع = et quart"
    },
    {
      context: "Que signifie صَبَاحًا ?",
      verb: "صَبَاحًا",
      info: "",
      correct: "Le matin",
      options: ["Le matin", "Le soir", "L'après-midi", "La nuit"],
      explanation: "صَبَاحًا = le matin (de صَبَاح, le matin)",
      frOptions: true
    },
    {
      context: "Quelle heure indique-t-on ?",
      verb: "السَّاعَةُ الثَّانِيَة وَالرُّبْع",
      info: "",
      correct: "2:15",
      options: ["2:15", "2:30", "2:45", "4:15"],
      explanation: "الثَّانِيَة وَالرُّبْع = deux heures et quart = 2:15",
      frOptions: true
    },
    {
      context: "Comment dit-on « le soir » ?",
      verb: "Le soir",
      info: "Quel moment de la journée ?",
      correct: "مَسَاءً",
      options: ["مَسَاءً", "صَبَاحًا", "لَيْلًا", "ظُهْرًا"],
      explanation: "مَسَاءً = le soir, d'où مَسَاءُ الخَيْر (bonsoir)"
    },
    {
      context: "Que signifie إِلَّا ?",
      verb: "إِلَّا",
      info: "Dans le contexte de l'heure",
      correct: "Moins / sauf",
      options: ["Moins / sauf", "Et / plus", "Pile / exactement", "Après"],
      explanation: "إِلَّا = sauf, moins. Utilisé pour « moins le quart », « moins vingt », etc.",
      frOptions: true
    },
    {
      context: "Comment dit-on « il est midi » ?",
      verb: "12:00",
      info: "",
      correct: "السَّاعَةُ الثَّانِيَةَ عَشْرَةَ",
      options: ["السَّاعَةُ الثَّانِيَةَ عَشْرَةَ", "السَّاعَةُ العَاشِرَة", "السَّاعَةُ الحَادِيَةَ عَشْرَةَ", "السَّاعَةُ الوَاحِدَة"],
      explanation: "الثَّانِيَةَ عَشْرَةَ = douzième = 12:00"
    },
    {
      context: "Que signifie نِصْف ?",
      verb: "نِصْف",
      info: "",
      correct: "Demi(e) / moitié",
      options: ["Demi(e) / moitié", "Quart", "Tiers", "Minute"],
      explanation: "نِصْف = moitié, demi(e). وَالنِّصْف = et demie.",
      frOptions: true
    },
    {
      context: "Quelle heure indique-t-on ?",
      verb: "السَّاعَةُ الرَّابِعَة وَالثُّلْث",
      info: "",
      correct: "4:20",
      options: ["4:20", "4:30", "4:15", "3:20"],
      explanation: "الرَّابِعَة وَالثُّلْث = quatre heures et un tiers = 4:20",
      frOptions: true
    },
    {
      context: "Comment dit-on « maintenant » ?",
      verb: "Maintenant",
      info: "",
      correct: "الآن",
      options: ["الآن", "غَدًا", "أَمْسِ", "بَعْدَ"],
      explanation: "الآن = maintenant. كَمِ السَّاعَةُ الآن؟ = quelle heure est-il maintenant ?"
    },
    {
      context: "Pourquoi dit-on الخَامِسَة (féminin) et non الخَامِس ?",
      verb: "السَّاعَةُ الخَامِسَة",
      info: "Question de grammaire",
      correct: "Parce que سَاعَة est féminin",
      options: ["Parce que سَاعَة est féminin", "Parce que c'est toujours féminin", "Par habitude, sans raison", "Parce que c'est l'après-midi"],
      explanation: "Le nombre ordinal s'accorde avec سَاعَة qui est un mot féminin.",
      frOptions: true
    },
  ];

  interface QuizQuestion {
    context: string;
    verb: string;
    info: string;
    correct: string;
    options: string[];
    explanation: string;
    frOptions?: boolean;
  }

  let currentQuestion = 0;
  let score = 0;
  let totalAnswered = 0;
  let shuffledQuestions: QuizQuestion[] = [];
  let answered = false;

  function shuffleArray<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function loadQuestion() {
    answered = false;

    if (currentQuestion >= shuffledQuestions.length) {
      shuffledQuestions = shuffleArray(quizQuestions);
      currentQuestion = 0;
    }

    const q = shuffledQuestions[currentQuestion];
    document.getElementById('quiz-context')!.textContent = q.context;
    const verbEl = document.getElementById('quiz-verb')!;
    verbEl.textContent = q.verb;
    verbEl.style.direction = /[\u0600-\u06FF]/.test(q.verb) ? 'rtl' : 'ltr';
    document.getElementById('quiz-info')!.textContent = q.info;

    const optionsDiv = document.getElementById('quiz-options')!;
    optionsDiv.innerHTML = '';

    const shuffledOptions = shuffleArray(q.options);
    shuffledOptions.forEach(opt => {
      const btn = document.createElement('div');
      btn.className = q.frOptions ? 'quiz-option fr-option' : 'quiz-option';
      btn.textContent = opt;
      btn.addEventListener('click', () => checkAnswer(btn, opt, q));
      optionsDiv.appendChild(btn);
    });

    document.getElementById('quiz-feedback')!.className = 'quiz-feedback';
    document.getElementById('quiz-feedback')!.style.display = 'none';
    document.getElementById('next-btn')!.style.display = 'none';
  }

  function checkAnswer(btn: HTMLElement, selected: string, question: QuizQuestion) {
    if (answered) return;
    answered = true;

    const options = document.querySelectorAll('.quiz-option');
    options.forEach(o => o.classList.add('disabled'));

    const feedback = document.getElementById('quiz-feedback')!;

    if (selected === question.correct) {
      score++;
      btn.classList.add('correct');
      feedback.className = 'quiz-feedback show correct';
      feedback.innerHTML = `Correct! ${question.explanation}`;
      document.getElementById('score')!.textContent = String(score);
    } else {
      btn.classList.add('wrong');
      options.forEach(o => {
        if (o.textContent === question.correct) o.classList.add('correct');
      });
      feedback.className = 'quiz-feedback show wrong';
      feedback.innerHTML = `La bonne réponse était <strong>${question.correct}</strong>. ${question.explanation}`;
    }

    document.getElementById('next-btn')!.style.display = 'inline-block';
  }

  function nextQuestion() {
    totalAnswered++;
    document.getElementById('progress')!.textContent = String(totalAnswered);
    currentQuestion++;
    loadQuestion();
  }

  document.getElementById('next-btn')!.addEventListener('click', nextQuestion);

  shuffledQuestions = shuffleArray(quizQuestions);
  document.getElementById('total')!.textContent = String(quizQuestions.length);
  loadQuestion();
</script>
