    border-radius: 8px;
    direction: rtl;
    display: block;
  }

  .struct-subject { background: var(--teal-light); color: var(--teal); }
  .struct-adj { background: var(--accent-light); color: var(--accent-dark); }
  .struct-fraction { background: #f0e6f6; color: #6a3d9a; font-size: 1.1rem; }
  .struct-plus { font-size: 1.5rem; color: var(--text-light); }

  .struct-label {
    font-size: 0.75rem;
