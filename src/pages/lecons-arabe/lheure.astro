  /* Time of day cards */
  .time-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.8rem;
    margin: 1.5rem 0;
  }

  .time-card {
    text-align: center;
    padding: 1.2rem 0.8rem;
    border-radius: var(--radius);
