            <td class="verb-ar">سَابِع</td>
            <td class="verb-ar">سَابِعَة</td>
          </tr>
          <tr class="pattern-row">
            <td class="num-col">8</td>
            <td class="verb-ar">ثَمَانِيَة</td>
            <td class="meaning-col">ث م ن</td>
            <td class="verb-ar">ثَامِن</td>
            <td class="verb-ar">ثَامِنَة</td>
          </tr>
