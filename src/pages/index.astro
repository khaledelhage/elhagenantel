---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="El-Hage Nantel" description="Site personnel de la famille El-Hage Nantel.">

<header>
  <div class="header-bg"></div>
  <div class="header-content">
    <h1>El-Hage Nantel</h1>
  </div>
</header>

<main>
  <div class="sections-grid">
    <a href="/lecons-arabe/" class="section-card">
      <div class="section-icon"><span class="icon-arabic">ض</span></div>
      <div class="section-body">
        <h2>Leçons d'arabe</h2>
        <p class="section-arabic">دُرُوسٌ فِي اللُّغَةِ العَرَبِيَّة</p>
        <p class="section-desc">Vocabulaire, grammaire et expressions avec quiz interactifs et mnémoniques.</p>
      </div>
      <div class="section-arrow">→</div>
    </a>
  </div>
</main>

<footer>
  <p>&copy; {new Date().getFullYear()} El-Hage Nantel</p>
</footer>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Lora', Georgia, serif;
    background: #faf7f2;
    color: #2c2c2c;
    line-height: 1.7;
  }

  /* Header */
  header {
    position: relative;
    background: #1a1a2e;
    color: #fff;
    text-align: center;
    padding: 4rem 2rem 4.5rem;
    overflow: hidden;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(196,135,59,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(42,122,110,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .header-content {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
  }

  header h1 {
    font-size: 2.4rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }

  .header-subtitle {
    font-size: 1.05rem;
    opacity: 0.7;
    line-height: 1.6;
  }

  /* Main */
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
  }

  /* Section cards */
  .sections-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: #fff;
    border: 1px solid #e8e0d4;
    border-radius: 12px;
    padding: 2rem 2.2rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .section-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    border-color: #c4873b;
  }

  .icon-arabic {
    font-family: 'Amiri', serif;
    font-size: 2.8rem;
    color: #c4873b;
    line-height: 1;
  }

  .section-icon {
    font-size: 2.8rem;
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5e6d0;
    border-radius: 14px;
  }

  .section-body {
    flex: 1;
    min-width: 0;
  }

  .section-body h2 {
    font-size: 1.3rem;
    color: #1a1a2e;
    margin-bottom: 0.15rem;
  }

  .section-arabic {
    font-family: 'Amiri', serif;
    font-size: 1.3rem;
    color: #c4873b;
    direction: rtl;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    font-size: 0.9rem;
    color: #6b6b6b;
    line-height: 1.5;
    margin: 0;
  }

  .section-arrow {
    font-size: 1.6rem;
    color: #c4873b;
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-5px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .section-card:hover .section-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Footer */
  footer {
    text-align: center;
    padding: 2rem;
    color: #6b6b6b;
    font-size: 0.85rem;
    border-top: 1px solid #e8e0d4;
    margin-top: 2rem;
  }

  /* Responsive */
  @media (max-width: 600px) {
    header { padding: 3rem 1.5rem 3.5rem; }
    header h1 { font-size: 1.8rem; }

    .section-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.5rem;
    }

    .section-arrow { display: none; }
  }
</style>
